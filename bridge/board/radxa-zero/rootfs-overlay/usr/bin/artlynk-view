#!/bin/sh
# artlynk-view — HDMI state machine for the ArtLynk bridge.
#   no goggle USB link                         -> splash "Connect goggle"
#   goggle linked, but tap sends nothing (no drone bound) -> splash "Connect the drone"
#   H.265 flowing from the venc8 tap           -> decode -> live video on HDMI
# Everything renders to the single HDMI via kmssink (only one owner at a time, so we swap on
# each state change). The venc8 tap forces a keyframe on every client connect, so reconnecting
# re-syncs cleanly after a goggle/drone power-cycle.
[ -r /etc/artlynk/bridge.conf ] && . /etc/artlynk/bridge.conf
IP="${GOGGLE_IP:-10.55.0.1}"; PORT="${GOGGLE_PORT:-9000}"; DECODE="${DECODE:-hw}"
HOST_CIDR="${HOST_CIDR:-10.55.0.2/24}"
SP_GOGGLE=/etc/artlynk/splash-no-goggle.png
SP_DRONE=/etc/artlynk/splash-no-drone.png

# Decoder element: prefer the Amlogic stateless HW HEVC decoder; fall back to software (gst-libav).
if   [ "$DECODE" = hw ] && gst-inspect-1.0 v4l2slh265dec >/dev/null 2>&1; then DEC="v4l2slh265dec"
elif [ "$DECODE" = hw ] && gst-inspect-1.0 v4l2h265dec  >/dev/null 2>&1; then DEC="v4l2h265dec"
else DEC="avdec_h265 ! videoconvert"; fi
echo "artlynk-view: tap=tcp://$IP:$PORT decoder=[$DEC]"

SPLASH_PID=""; CUR=""
stop_splash() { [ -n "$SPLASH_PID" ] && kill "$SPLASH_PID" 2>/dev/null; SPLASH_PID=""; }
show_splash() {   # $1 = png; (re)start only if it isn't already the one on screen
	if [ "$CUR" = "$1" ] && [ -n "$SPLASH_PID" ] && kill -0 "$SPLASH_PID" 2>/dev/null; then return; fi
	stop_splash; sleep 1   # let the previous kmssink release the DRM master
	gst-launch-1.0 filesrc location="$1" ! pngdec ! imagefreeze ! videoconvert ! \
		kmssink force-modesetting=true >/dev/null 2>&1 &
	SPLASH_PID=$!; CUR="$1"
}

ensure_link() {   # goggle present? find its cdc_ether, give ourselves the host IP. 0 = linked.
	# Force the OTG to HOST mode. The goggle *sources* power, so the USB-C port otherwise comes up
	# in device mode (role-switch defaults to "device") and never enumerates the goggle's ECM.
	for rs in /sys/class/usb_role/*/role; do
		[ -e "$rs" ] && [ "$(cat "$rs" 2>/dev/null)" != host ] && echo host > "$rs" 2>/dev/null
	done
	for n in /sys/class/net/*; do
		case "$(readlink "$n/device/driver" 2>/dev/null)" in
			*cdc_ether*)
				IF=$(basename "$n")
				ip link set "$IF" up 2>/dev/null
				ip addr show "$IF" 2>/dev/null | grep -q "${HOST_CIDR%/*}" || \
					ip addr add "$HOST_CIDR" dev "$IF" 2>/dev/null
				return 0;;
		esac
	done
	return 1
}

stream_up() {     # This busybox has no `nc`, so probe with GStreamer. A live stream delivers buffers
                  # at once (drone bound + encoding); an idle tap (no drone) or no tap stalls and
                  # times out. Needs 8 buffers within 4s — the tap's connect-time params alone won't
                  # reach that, so we don't false-start the decoder.
	gst-launch-1.0 tcpclientsrc host="$IP" port="$PORT" timeout=4 num-buffers=8 ! fakesink >/dev/null 2>&1
}

while true; do
	if ! ensure_link; then
		show_splash "$SP_GOGGLE"; sleep 2
	elif ! stream_up; then
		show_splash "$SP_DRONE"; sleep 2
	else
		stop_splash; CUR=""; sleep 1
		echo "artlynk-view: stream up -> decoding"
		# NOTE: do NOT use a leaky queue here — SW HEVC decode is slow, the queue fills instantly,
		# and leaky=downstream would drop the oldest buffer = the IDR keyframe, leaving only P-frames
		# painting motion onto grey. config-interval=-1 re-sends VPS/SPS/PPS so the decoder can sync.
		gst-launch-1.0 -e tcpclientsrc host="$IP" port="$PORT" timeout=5 ! \
			h265parse config-interval=-1 ! queue ! $DEC ! \
			kmssink force-modesetting=true sync=false
		echo "artlynk-view: stream ended -> re-checking state"
	fi
done
