#!/bin/sh
# Add a UVC (webcam) function to the already-running ECM gadget, making the bridge a *composite*
# ECM+UVC device: SSH (10.66.0.1) stays, plus the Mac sees a webcam. Idempotent + iterable over SSH.
#
#   uvc-gadget-up [WIDTH HEIGHT FPS]   default 1280 720 30
#
# How it works: configfs lets a gadget carry several functions, but the UDC bind happens once with all
# functions present. The boot script (S30usbgadget) binds ECM only; this unbinds, adds uvc.0, rebinds.
# The kernel f_uvc then creates a /dev/videoN node that `uvcsink` streams MJPEG into (see uvc-stream).
set -e
W="${1:-1280}"; H="${2:-720}"; FPS="${3:-30}"
INTERVAL=$(( 10000000 / FPS ))          # frame interval in 100ns units (e.g. 30fps -> 333333)
G=/sys/kernel/config/usb_gadget/g1
U="$G/functions/uvc.0"

[ -d "$G" ] || { echo "uvc-gadget-up: no gadget g1 (is S30usbgadget up?)"; exit 1; }
[ -d /sys/class/udc ] || { echo "uvc-gadget-up: no UDC"; exit 1; }
UDC=$(ls /sys/class/udc/ | head -n1)

echo "uvc-gadget-up: unbinding gadget (SSH will blip)..."
echo "" > "$G/UDC" 2>/dev/null || true

if [ ! -d "$U" ]; then
	echo "uvc-gadget-up: creating uvc.0 (MJPEG ${W}x${H}@${FPS})"
	mkdir -p "$U"
	# control: one header, linked into the fs/ss speed classes
	mkdir -p "$U/control/header/h"
	ln -sf "$U/control/header/h" "$U/control/class/fs/h"
	ln -sf "$U/control/header/h" "$U/control/class/ss/h"
	# streaming: a single MJPEG format 'm' with one frame
	F="$U/streaming/mjpeg/m/f"
	mkdir -p "$F"
	echo "$W" > "$F/wWidth"
	echo "$H" > "$F/wHeight"
	echo $(( W * H * 2 ))            > "$F/dwMaxVideoFrameBufferSize"
	echo "$INTERVAL"                 > "$F/dwDefaultFrameInterval"
	echo $(( W * H * 2 * FPS * 8 ))  > "$F/dwMinBitRate"
	echo $(( W * H * 2 * FPS * 8 ))  > "$F/dwMaxBitRate"
	printf '%s\n' "$INTERVAL"        > "$F/dwFrameInterval"
	# streaming header links the format, then is linked into the speed classes
	mkdir -p "$U/streaming/header/h"
	ln -sf "$U/streaming/mjpeg/m" "$U/streaming/header/h/m"
	ln -sf "$U/streaming/header/h" "$U/streaming/class/fs/h"
	ln -sf "$U/streaming/header/h" "$U/streaming/class/hs/h"
	ln -sf "$U/streaming/header/h" "$U/streaming/class/ss/h"
	# bandwidth knobs (USB2 high-speed): big packets help MJPEG fit
	echo 2048 > "$U/streaming_maxpacket" 2>/dev/null || true
fi

# link uvc.0 into the config (no-op if already linked)
ln -sf "$U" "$G/configs/c.1/uvc.0" 2>/dev/null || true

echo "uvc-gadget-up: rebinding to $UDC ..."
echo "$UDC" > "$G/UDC"

# report the f_uvc video node (the one whose name mentions uvc, not the decoder)
sleep 1
for v in /sys/class/video4linux/video*; do
	n=$(cat "$v/name" 2>/dev/null || echo)
	case "$n" in *uvc*|*UVC*|*gadget*) echo "uvc-gadget-up: UVC node = /dev/$(basename "$v")  ($n)";; esac
done
echo "uvc-gadget-up: done — composite ECM+UVC is live"
