#!/bin/sh
# Stream MJPEG into the UVC gadget node via GStreamer's uvcsink (gst>=1.24), so the Mac sees a webcam.
#   uvc-stream test            test pattern (Phase 1: prove the Mac enumerates + shows video)
#   uvc-stream live [IP PORT]   goggle venc8 H.265 tap -> HW decode -> MJPEG -> webcam (default 10.55.0.1 9000)
#
# Run `uvc-gadget-up` first (creates the f_uvc node). uvcsink wraps a child v4l2sink; we point it at
# the gadget's /dev/videoN. NB: open Photo Booth/QuickTime on the Mac to pull frames (uvcsink only
# pushes once the host starts streaming).
set -e
MODE="${1:-test}"
W=1280; H=720; FPS=30

# find the f_uvc gadget video node: the video node that is NOT the meson HW decoder. The gadget node is
# named after the UDC (e.g. "ff400000.usb"). Short retry since it appears right after the gadget binds.
DEV=""
i=0
while [ $i -lt 10 ]; do
	for v in /sys/class/video4linux/video*; do
		[ -e "$v" ] || continue
		n=$(cat "$v/name" 2>/dev/null)
		case "$n" in
			""|*meson*|*decoder*|*vdec*|*decode*) : ;;
			*) DEV="/dev/$(basename "$v")"; break;;
		esac
	done
	[ -n "$DEV" ] && break
	i=$((i+1)); sleep 0.5
done
[ -n "$DEV" ] || { echo "uvc-stream: no UVC gadget node found — is the gadget bound with uvc.0?"; exit 1; }
echo "uvc-stream: UVC node = $DEV  (mode: $MODE)"

CAPS="video/x-raw,width=$W,height=$H,framerate=$FPS/1"

case "$MODE" in
  test)
	exec gst-launch-1.0 -v \
		videotestsrc is-live=true pattern=ball ! $CAPS ! videoconvert ! \
		avenc_mjpeg ! "image/jpeg,width=$W,height=$H,framerate=$FPS/1" ! \
		uvcsink name=uvc v4l2sink::device=$DEV
	;;
  live)
	IP="${2:-10.55.0.1}"; PORT="${3:-9000}"
	exec gst-launch-1.0 -v \
		tcpclientsrc host=$IP port=$PORT ! queue ! h265parse ! v4l2slh265dec ! \
		videoconvert ! videoscale ! $CAPS ! \
		avenc_mjpeg ! "image/jpeg,width=$W,height=$H,framerate=$FPS/1" ! \
		uvcsink name=uvc v4l2sink::device=$DEV
	;;
  *) echo "usage: uvc-stream {test|live [IP PORT]}"; exit 1;;
esac
