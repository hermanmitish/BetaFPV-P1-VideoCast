#!/bin/sh
# Bring up the USB CDC-ECM link to the goggle. The goggle is the USB *device* (it presents an ECM
# gadget); we are the *host*, so its network interface shows up here (driver: cdc_ether). We just
# give ourselves the host IP — same role the Mac plays in the desktop setup.
[ -r /etc/artlynk/bridge.conf ] && . /etc/artlynk/bridge.conf
HOST_CIDR="${HOST_CIDR:-10.55.0.2/24}"

find_ecm_if() {
	for n in /sys/class/net/*; do
		drv=$(readlink "$n/device/driver" 2>/dev/null)
		case "$drv" in *cdc_ether*) basename "$n"; return;; esac
	done
}

case "$1" in
	start)
		printf "Waiting for goggle USB-ECM link"
		IF=""
		for i in $(seq 1 30); do
			IF=$(find_ecm_if); [ -n "$IF" ] && break
			printf "."; sleep 1
		done
		echo
		if [ -n "$IF" ]; then
			ip addr add "$HOST_CIDR" dev "$IF" 2>/dev/null
			ip link set "$IF" up
			echo "usbnet: $IF -> $HOST_CIDR"
		else
			echo "usbnet: no CDC-ECM interface yet (goggle off? it'll be retried by artlynk-view)"
		fi
		;;
	stop) ;;
	*) echo "Usage: $0 {start|stop}"; exit 1;;
esac
