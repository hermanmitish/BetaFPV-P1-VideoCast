#!/bin/sh
# S41wifi — bring up the on-board Broadcom SDIO WiFi (brcmfmac wlan0) + wpa_supplicant + DHCP, so the
# bridge is reachable over the home network for SSH (the UVC gadget breaks ECM-over-USB, so WiFi is the
# management link). Non-fatal if the chip/firmware isn't ready — the camera path doesn't depend on it.
case "$1" in
  start)
	# wait for wlan0 to appear (brcmfmac probe + firmware load can lag)
	i=0
	while [ $i -lt 15 ]; do [ -e /sys/class/net/wlan0 ] && break; sleep 1; i=$((i+1)); done
	if [ ! -e /sys/class/net/wlan0 ]; then
		echo "S41wifi: no wlan0 — check 'dmesg | grep brcmfmac' for the firmware/nvram it wants"
		exit 0
	fi
	ip link set wlan0 up 2>/dev/null || ifconfig wlan0 up 2>/dev/null
	wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant.conf > /var/log/wpa.log 2>&1
	sleep 3
	udhcpc -i wlan0 -b -t 8 -p /var/run/udhcpc.wlan0.pid > /var/log/udhcpc.log 2>&1 &
	sleep 4
	echo "S41wifi: wlan0 $(ip -4 addr show wlan0 2>/dev/null | grep -o 'inet [0-9.]*' || echo '(no IP yet)')"
	;;
  stop)
	killall udhcpc wpa_supplicant 2>/dev/null
	;;
  *) echo "Usage: $0 {start|stop}"; exit 1 ;;
esac
